# Leave unset to use deterministic mock planning.
OPENAI_API_KEY=

# Optional future providers for live accommodation search.
SEARCH_PROVIDER=mock
SERPAPI_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=

# PDF email delivery. Keep unset to use download-only mode.
RESEND_API_KEY=
EMAIL_FROM=Atlas Exchange <reports@example.com>
REPORT_EMAIL_ALLOWLIST=student@example.com
APP_ORIGIN=http://localhost:3003

# Enable only behind a proxy such as Vercel that overwrites forwarding headers.
TRUST_PROXY_HEADERS=false

# Cost guardrails.
MAX_SOURCE_SNIPPETS=6
MAX_OUTPUT_TOKENS=1800
