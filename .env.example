# Leave unset to use deterministic mock planning.
# Also powers live university research (cost of living, CCAs, weekend
# plans) in the "Compare" tab via the OpenAI Responses API with web search.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional future providers for live accommodation search.
SEARCH_PROVIDER=mock
SERPAPI_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=

# Enable only behind a proxy such as Vercel that overwrites forwarding headers.
TRUST_PROXY_HEADERS=false

# Cost guardrails.
MAX_SOURCE_SNIPPETS=6
MAX_OUTPUT_TOKENS=1800
